{
  "applicationId": "dev.deviverr.neku",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/resources/",
  "url": "/editor/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": { "enabled": false, "writeToLogFile": false },
  "nativeAllowList": ["app.*", "os.*", "filesystem.*", "window.*", "clipboard.*", "events.*"],
  "modes": {
    "window": {
      "title": "Neku Studio",
      "width": 1440,
      "height": 900,
      "minWidth": 960,
      "minHeight": 620,
      "center": true,
      "icon": "/resources/icons/icon-512.png",
      "enableInspector": false,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "neku-studio",
    "resourcesPath": "/resources/",
    "extensionsPath": "",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "5.3.0",
    "clientVersion": "5.3.0"
  }
}
